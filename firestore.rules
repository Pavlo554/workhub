rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Хелпер: перевірка чи юзер є адміном ─────────────────
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── Профілі користувачів ─────────────────────────────────
    match /users/{userId} {
      // Адмін читає і пише всіх (зміна плану, isAdmin), юзер — тільки себе
      allow read:  if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // ── Підколекції юзера (notes, passwords, clients і т.д.) ─
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
    }

    // ── Платежі (collectionGroup для адміна) ─────────────────
    match /{path=**}/pendingPayments/{paymentId} {
      allow read:   if request.auth != null && isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // ── Воркспейси ───────────────────────────────────────────
    match /workspaces/{workspaceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == workspaceId;

      match /members/{memberId} {
        allow read: if request.auth != null &&
          (request.auth.uid == workspaceId || request.auth.uid == memberId);
        allow create: if request.auth != null && request.auth.uid == memberId;
        allow update, delete: if request.auth != null && request.auth.uid == workspaceId;
      }

      match /invites/{inviteCode} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == workspaceId;
        allow update: if request.auth != null &&
          (request.auth.uid == workspaceId || resource.data.used == false);
      }
    }

    // ── Запрошення (root) ─────────────────────────────────────
    match /invites/{inviteCode} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.workspaceId;
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.workspaceId || resource.data.used == false);
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.workspaceId;
    }

  }
}
