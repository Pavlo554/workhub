rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Owner — single source of truth is config/ownerClaim (immutable once set).
    // We don't trust users/{uid}.isOwner alone, since that field could otherwise
    // be spoofed by a direct write if any rule branch were misconfigured.
    function isOwner() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/config/ownerClaim) &&
        get(/databases/$(database)/documents/config/ownerClaim).data.uid == request.auth.uid;
    }

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Does the current admin's assigned role include this admin-panel tab?
    function hasTabAccess(tab) {
      let roleId = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('adminRoleId', null);
      return roleId != null &&
        exists(/databases/$(database)/documents/adminRoles/$(roleId)) &&
        tab in get(/databases/$(database)/documents/adminRoles/$(roleId)).data.get('allowedTabs', []);
    }

    function isNotBanned() {
      return request.auth != null &&
        !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false);
    }

    function isWorkspaceMember(ownerId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/workspaces/$(ownerId)/members/$(request.auth.uid));
    }

    // Fields only admin / Cloud Functions may change
    function touchesProtectedFields() {
      let protected = [
        'isAdmin', 'isOwner', 'adminRoleId', 'isBanned',
        'plan', 'subscriptionEnd', 'planExpiresAt',
        'subscriptionStatus', 'planActivatedAt', 'planMethod'
      ];
      return resource == null
        ? request.resource.data.keys().hasAny(protected)
        : request.resource.data.diff(resource.data).affectedKeys().hasAny(protected);
    }

    // Privilege fields — only Owner may grant/revoke these on ANY user doc
    function touchesOwnerFields() {
      let ownerFields = ['isAdmin', 'isOwner', 'adminRoleId'];
      return resource == null
        ? request.resource.data.keys().hasAny(ownerFields)
        : request.resource.data.diff(resource.data).affectedKeys().hasAny(ownerFields);
    }

    // One-time self-claim: a user may set isOwner:true on their OWN doc,
    // and only that field, and only while nobody has claimed ownership yet.
    function isFirstOwnerClaim(userId) {
      return request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isOwner']) &&
        request.resource.data.isOwner == true &&
        !exists(/databases/$(database)/documents/config/ownerClaim);
    }

    // Subcollections workspace members must NOT read/write
    // Takes the first path segment (subcollection name), not the full path
    function isSensitivePath(subcol) {
      return subcol == 'passwords'    ||
             subcol == 'bank_accounts' ||
             subcol == 'bank-accounts' ||
             subcol == 'payroll'      ||
             subcol == 'api-keys'     ||
             subcol == 'api_keys'     ||
             subcol == 'subscriptionHistory' ||
             subcol == 'loginEvents'  ||
             subcol == 'prro';
    }

    // ── 2FA secrets — STRICTLY self-only. No isAdmin()/isOwner() bypass here:
    // an admin must never be able to read another account's TOTP secret,
    // otherwise 2FA protection would be meaningless against a malicious admin.
    match /twoFactorSecrets/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Owner claim (singleton, immutable) ──────────────────────────────────
    match /config/ownerClaim {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Admin audit log — write-only for admins, readable only by Owner ─────
    match /adminLogs/{logId} {
      allow create: if (isAdmin() || isOwner()) && request.resource.data.actorUid == request.auth.uid;
      allow read:   if isOwner();
      allow update, delete: if false;
    }

    // ── Support reply templates (admins with "support" tab access) ──────────
    match /supportTemplates/{tplId} {
      allow read, write: if isOwner() || (isAdmin() && hasTabAccess('support'));
    }

    // ── Admin roles (Owner manages, any admin can read to resolve own role) ─
    match /adminRoles/{roleId} {
      allow read:  if isAdmin() || isOwner();
      allow write: if isOwner();
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || isOwner() || isWorkspaceMember(userId));

      // New account creation: allow only safe default values
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.get('plan', 'free') == 'free' &&
        request.resource.data.get('isAdmin', false) == false &&
        request.resource.data.get('isOwner', false) == false &&
        request.resource.data.get('isBanned', false) == false &&
        !request.resource.data.keys().hasAny(['subscriptionEnd', 'planExpiresAt', 'subscriptionStatus', 'planActivatedAt', 'planMethod', 'adminRoleId']);

      // Updates:
      //  - Owner: unrestricted
      //  - Tab-scoped admin ("users" tab): everything except privilege fields
      //  - Self: everything except protected fields
      //  - Anyone: one-time self-claim of ownership (only before anyone owns it)
      allow update: if request.auth != null && (
        isOwner() ||
        (isAdmin() && hasTabAccess('users') && !touchesOwnerFields()) ||
        (request.auth.uid == userId && !touchesProtectedFields()) ||
        isFirstOwnerClaim(userId)
      );

      allow delete: if isOwner() || (isAdmin() && hasTabAccess('users'));
    }

    // {subcol}/{doc=**} requires at least ONE path segment after userId,
    // so it never accidentally matches the /users/{userId} document itself
    // (rules_version 2 allows {x=**} to match zero segments — that's the bug we avoid)
    match /users/{userId}/{subcol}/{doc=**} {
      allow read, write: if request.auth != null && isNotBanned() && (
        request.auth.uid == userId ||
        isOwner() ||
        (isAdmin() && hasTabAccess('users')) ||
        (isWorkspaceMember(userId) && !isSensitivePath(subcol))
      );
    }

    // ── Tickets ────────────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || isOwner() || (isAdmin() && hasTabAccess('support'))
      );
      // Rate limit: max 1 new ticket per 60s per user (checks users/{uid}.lastTicketAt)
      allow create: if request.auth != null && isNotBanned() &&
        request.auth.uid == request.resource.data.userId &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('lastTicketAt', null) == null ||
          request.time > get(/databases/$(database)/documents/users/$(request.auth.uid)).data.lastTicketAt + duration.value(60, 's')
        );
      // Prevent userId substitution on update
      allow update: if request.auth != null && (
        isOwner() || (isAdmin() && hasTabAccess('support')) ||
        (resource.data.userId == request.auth.uid &&
         request.resource.data.userId == resource.data.userId)
      );
      allow delete: if isOwner() || (isAdmin() && hasTabAccess('support'));
    }

    // ── Announcements ──────────────────────────────────────────────────────
    match /announcements/{id} {
      allow read:  if request.auth != null;
      allow write: if isOwner() || (isAdmin() && hasTabAccess('notifications'));
    }

    // ── FAQ — public read, admin-managed ────────────────────────────────────
    match /faq/{id} {
      allow read:  if request.auth != null;
      allow write: if isOwner() || (isAdmin() && hasTabAccess('faq'));
    }

    // ── Config — sensitive docs MUST come before the wildcard ──────────────
    // Payment signing secrets: write-only from the client. Only the Cloud
    // Function that signs AIFO requests reads this (via Admin SDK, which
    // bypasses these rules entirely) — no client, including admins, can
    // read the live secret key back out of Firestore.
    match /config/aifo_keys {
      allow read:  if false;
      allow write: if isOwner() || (isAdmin() && hasTabAccess('payments'));
    }
    match /config/telegram {
      allow read, write: if isOwner() || (isAdmin() && hasTabAccess('payments'));
    }

    // Public payment config (crypto addresses, monobank jar, aifo shop id)
    match /config/payments {
      allow read:  if request.auth != null;
      allow write: if isOwner() || (isAdmin() && hasTabAccess('payments'));
    }

    // All other config — wildcard explicitly excludes sensitive docs
    // (Firestore ORs all matching rules, so the exclusion here is mandatory)
    match /config/{docId} {
      allow read: if request.auth != null &&
        docId != 'telegram' && docId != 'ownerClaim' && docId != 'aifo_keys';
      allow write: if isOwner() || isAdmin();
    }

    // ── Error Logs ─────────────────────────────────────────────────────────
    match /errors/{errorId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isOwner() || (isAdmin() && hasTabAccess('errors'));
    }

    // ── Pending Payments ───────────────────────────────────────────────────
    match /{path=**}/pendingPayments/{paymentId} {
      allow read:           if request.auth != null && (isOwner() || (isAdmin() && hasTabAccess('payments')));
      allow create:         if request.auth != null && isNotBanned();
      allow update, delete: if request.auth != null && (isOwner() || (isAdmin() && hasTabAccess('payments')));
    }

    // ── Workspaces ─────────────────────────────────────────────────────────
    match /workspaces/{workspaceId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == workspaceId;

      match /members/{memberId} {
        allow read: if request.auth != null &&
          (request.auth.uid == workspaceId || request.auth.uid == memberId);
        // Require valid, unused invite code
        allow create: if request.auth != null &&
          request.auth.uid == memberId &&
          request.resource.data.inviteCode != null &&
          exists(/databases/$(database)/documents/workspaces/$(workspaceId)/invites/$(request.resource.data.inviteCode)) &&
          get(/databases/$(database)/documents/workspaces/$(workspaceId)/invites/$(request.resource.data.inviteCode)).data.get('used', false) == false;
        allow update: if request.auth != null && request.auth.uid == workspaceId;
        allow delete: if request.auth != null &&
          (request.auth.uid == workspaceId || request.auth.uid == memberId);
      }

      match /invites/{inviteCode} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == workspaceId;
        allow update: if request.auth != null && (
          request.auth.uid == workspaceId ||
          (
            resource.data.get('used', false) == false &&
            request.resource.data.used == true &&
            request.resource.data.usedBy == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedBy', 'usedAt'])
          )
        );
      }
    }

    // ── Global Invites ─────────────────────────────────────────────────────
    match /invites/{inviteCode} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.workspaceId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.workspaceId ||
        (
          resource.data.get('used', false) == false &&
          request.resource.data.used == true &&
          request.resource.data.usedBy == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedBy', 'usedAt'])
        )
      );
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.workspaceId;
    }

    // ── Client Portals ─────────────────────────────────────────────────────
    match /clientPortals/{token} {
      // Owner can create/update their portal tokens
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.ownerUid;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.ownerUid;
      // Owner can read their own portal tokens; Vercel reads via Admin SDK (bypasses rules)
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.ownerUid;
    }

  }
}
