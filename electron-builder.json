{
  "appId": "com.workhub.app",
  "productName": "WorkHub",
  "copyright": "Copyright © 2026",
  "icon": "assets/icon.png",
  "directories": {
    "output": "dist"
  },
  "files": [
    "src/**/*",
    "assets/**/*",
    "package.json",
    "!src/**/*.map",
    "!**/node_modules/.cache/**"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "linux": {
    "target": [
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ],
    "category": "Office"
  },
  "publish": [{
    "provider": "github",
    "owner": "ТВІЙ_GITHUB_USERNAME",
    "repo": "workhub-releases",
    "private": false
  }],
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "WorkHub"
  }
}
